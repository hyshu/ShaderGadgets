{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["@webgpu/types"],
    "paths": {
      "react-native": ["./node_modules/react-native"],
      "react-native/*": ["./node_modules/react-native/*"],
      "typegpu": ["./node_modules/typegpu"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../shared-ts/**/*.ts", "../shared-ts/**/*.tsx"]
}
